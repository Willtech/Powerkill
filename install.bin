#!/bin/bash
## Powerkill Build Script
# Builds the Powerkill binary using shc + gcc
# Koji-safe, RPM-safe, no privileged operations
# Source Code produced by Willtech 2026
# v2.3 hand coded by HRjJ

set -e

echo "==> Building Powerkill"

# Ensure the script is executable
chmod +x powerkill

# Generate C source from the script
shc -f powerkill

# Compile the generated C file into a binary
gcc powerkill.x.c -o powerkill.bin

# Normalize output name (same pattern as groot)
if [ -f powerkill.bin ]; then
    mv powerkill.bin powerkill
fi

echo "==> Build complete: ./powerkill"
echo "==> Ready for RPM packaging"
